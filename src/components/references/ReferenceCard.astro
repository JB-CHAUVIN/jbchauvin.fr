---
import { type Lang } from '../../i18n/index';

interface Props {
  reference: any;
  lang: Lang;
}

const { reference, lang } = Astro.props;
const testimonial = reference.testimonial[lang];
const role = reference.role[lang];
---

<article class="border-l-2 border-gray-200 pl-5 py-1 mb-8">
  <blockquote class="text-sm text-gray-600 leading-relaxed italic mb-3 whitespace-pre-line">
    "{testimonial.text}"
  </blockquote>

  <div class="flex items-center gap-3">
    {reference.avatar && (
      <img
        src={reference.avatar}
        alt={testimonial.author}
        class="w-8 h-8 rounded-full object-cover grayscale flex-shrink-0"
        loading="lazy"
      />
    )}
    <div>
      <div class="text-sm font-semibold text-gray-800">{testimonial.author}</div>
      <div class="text-xs text-gray-500">
        {testimonial.position} · {reference.company} · {reference.period}
      </div>
      {reference.stack.length > 0 && (
        <div class="flex flex-wrap gap-1 mt-1">
          {reference.stack.map((tech: string) => (
            <span class="text-[10px] bg-gray-100 text-gray-400 px-1.5 py-0.5 rounded">{tech}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>
