---
import { type Lang } from '../../i18n/index';

interface Props {
  reference: any;
  lang: Lang;
}

const { reference, lang } = Astro.props;
const testimonial = reference.testimonial[lang];
const role = reference.role[lang];

const initials = testimonial.author
  .split(' ')
  .map((n: string) => n[0])
  .slice(0, 2)
  .join('');
---

<div class="retro-card reveal mb-3">
  <table cellpadding="4" cellspacing="0" class="w-full">
    <tr>
      <td class="align-top" style="width: 50px;">
        <div class="w-[40px] h-[40px] bg-[#000080] border-inset flex items-center justify-center text-white font-display text-[14px] overflow-hidden">
          {reference.avatar ? (
            <img
              src={reference.avatar}
              alt={testimonial.author}
              class="w-full h-full object-cover"
              loading="lazy"
              onerror={`this.style.display='none'; this.parentElement.innerHTML='<span style="font-family:Comic Sans MS,cursive;font-size:14px;">${initials}</span>'`}
            />
          ) : (
            <span>{initials}</span>
          )}
        </div>
      </td>
      <td class="align-top">
        <!-- Header -->
        <div class="flex flex-wrap items-baseline gap-2 mb-1">
          <span class="font-display text-[14px] text-[#000080] font-bold">
            {reference.company}
          </span>
          <span class="font-pixel text-[10px] text-ink-muted">{role} · {reference.period}</span>
        </div>

        <!-- Stack -->
        <div class="mb-2">
          {reference.stack.map((tech: string) => (
            <span class="retro-tag mr-1">{tech}</span>
          ))}
        </div>

        <!-- Testimonial -->
        <blockquote class="font-body text-[13px] text-ink-secondary leading-relaxed italic border-l-2 border-[#000080] pl-3 mb-2 whitespace-pre-line">
          "{testimonial.text}"
        </blockquote>

        <!-- Author -->
        <div class="font-pixel text-[12px]">
          — <strong class="text-[#000080]">{testimonial.author}</strong>,
          <span class="text-ink-muted">{testimonial.position}</span>
        </div>
      </td>
    </tr>
  </table>
</div>
