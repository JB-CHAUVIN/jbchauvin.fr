---
import { type Lang, getAlternatePath } from '../../i18n/index';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const isEn = lang === 'en';
const homeHref = isEn ? '/' : '/fr/';
const projectsHref = isEn ? '/projects/' : '/fr/projets/';
const referencesHref = isEn ? '/references/' : '/fr/references/';
const alternateLang: Lang = isEn ? 'fr' : 'en';
const alternatePath = getAlternatePath(currentPath, alternateLang);

function isActive(href: string) {
  if (href === '/' || href === '/fr/') return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 bg-white border-b border-gray-200 z-50">
  <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href={homeHref} class="text-sm font-semibold text-gray-900 hover:text-blue-700 transition-colors">
      Jean-Baptiste Chauvin
    </a>
    <nav class="flex items-center gap-5 text-sm">
      <a
        href={projectsHref}
        class={`transition-colors ${isActive(projectsHref) ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900'}`}
      >
        {isEn ? 'Projects' : 'Projets'}
      </a>
      <a
        href={referencesHref}
        class={`transition-colors ${isActive(referencesHref) ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900'}`}
      >
        {isEn ? 'References' : 'Références'}
      </a>
      <a
        href={alternatePath}
        class="text-xs border border-gray-300 rounded-sm px-2 py-0.5 text-gray-500 hover:border-gray-500 hover:text-gray-900 transition-colors"
      >
        {isEn ? 'FR' : 'EN'}
      </a>
    </nav>
  </div>
</header>
