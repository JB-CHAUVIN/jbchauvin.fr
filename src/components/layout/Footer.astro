---
import { type Lang } from '../../i18n/index';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="border-t border-gray-200 mt-16">
  <div class="max-w-3xl mx-auto px-6 h-12 flex items-center justify-between text-xs text-gray-400">
    <span>© 2026 Jean-Baptiste Chauvin</span>
    <div class="flex items-center gap-4">
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-gray-700 transition-colors">
        LinkedIn
      </a>
      <a href={site.github} target="_blank" rel="noopener noreferrer" class="hover:text-gray-700 transition-colors">
        GitHub
      </a>
      <a href={`mailto:${site.email}`} class="hover:text-gray-700 transition-colors">
        {site.email}
      </a>
    </div>
  </div>
</footer>
