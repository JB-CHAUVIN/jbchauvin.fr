---
import { useTranslations, type Lang } from '../../i18n/index';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="mb-4">
  <div class="section-label">{t('section.contact.title')}</div>

  <p class="text-sm text-gray-600 mb-4 max-w-lg">
    {t('section.contact.description')}
  </p>

  <div class="flex flex-wrap gap-3">
    <a
      href={`mailto:${site.email}`}
      class="text-sm font-medium text-gray-900 border border-gray-300 rounded px-4 py-2 hover:border-gray-500 hover:bg-gray-50 transition-colors"
    >
      {t('section.contact.email')}
    </a>
    <a
      href={site.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-medium text-gray-900 border border-gray-300 rounded px-4 py-2 hover:border-gray-500 hover:bg-gray-50 transition-colors"
    >
      {t('section.contact.linkedin')}
    </a>
  </div>
</section>
