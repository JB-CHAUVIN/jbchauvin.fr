---
import { useTranslations, type Lang } from '../../i18n/index';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="p-4">
  <hr class="rainbow-hr" />

  <!-- Contact section as a guestbook signing prompt -->
  <table cellpadding="0" cellspacing="0" class="w-full mb-4">
    <tr>
      <td class="bg-[#000080] p-2">
        <h2 class="!text-white text-[18px] m-0 font-display">
          &#9993; {t('section.contact.title')}
        </h2>
      </td>
    </tr>
  </table>

  <div class="retro-card text-center py-6 reveal">
    <div class="font-display text-[16px] text-[#000080] mb-2 sparkle">
      {t('section.contact.title')}
    </div>
    <p class="font-body text-[14px] text-ink-secondary mb-4 max-w-md mx-auto">
      {t('section.contact.description')}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href={`mailto:${site.email}`} class="retro-btn retro-btn-primary no-underline">
        &#128231; {t('section.contact.email')}
      </a>
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="retro-btn no-underline">
        &#128279; {t('section.contact.linkedin')}
      </a>
    </div>

    <div class="font-pixel text-[10px] text-ink-muted mt-4">
      {lang === 'en'
        ? 'You are visitor #3,847. Please sign my guestbook!'
        : 'Vous êtes le visiteur n°3 847. Signez mon livre d\'or !'}
    </div>
  </div>
</div>
