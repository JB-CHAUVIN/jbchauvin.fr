---
import { useTranslations, type Lang } from '../../i18n/index';
import Button from '../ui/Button.astro';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="max-w-6xl mx-auto px-6 lg:px-8 py-24">
  <div class="reveal max-w-2xl mx-auto text-center">
    <!-- Decorative line -->
    <div class="w-12 h-px bg-accent mx-auto mb-8"></div>

    <h2 class="font-display text-4xl md:text-5xl font-bold text-ink-primary mb-6">
      {t('section.contact.title')}
    </h2>
    <p class="font-body text-lg text-ink-secondary mb-10 leading-relaxed">
      {t('section.contact.description')}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <Button href={`mailto:${site.email}`} variant="primary" size="lg">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M1 4L8 9L15 4M1 4H15V12H1V4Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {t('section.contact.email')}
      </Button>
      <Button href={site.linkedin} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
        {t('section.contact.linkedin')}
      </Button>
    </div>
  </div>
</section>
