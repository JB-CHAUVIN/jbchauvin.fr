---
import { useTranslations, type Lang } from '../../i18n/index';
import Button from '../ui/Button.astro';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden">
  <div class="section-divider"></div>

  <!-- Aurora background for CTA -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="aurora-orb w-[500px] h-[500px] bg-accent/15 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-aurora"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-32 relative">
    <div class="reveal max-w-2xl mx-auto text-center">
      <!-- Decorative gradient line -->
      <div class="w-16 h-0.5 bg-gradient-aurora mx-auto mb-8 rounded-full"></div>

      <h2 class="font-display text-display-lg text-ink-primary mb-6">
        {t('section.contact.title')}
      </h2>
      <p class="font-body text-lg text-ink-secondary mb-10 leading-relaxed">
        {t('section.contact.description')}
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <Button href={`mailto:${site.email}`} variant="primary" size="lg">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M1 4L8 9L15 4M1 4H15V12H1V4Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {t('section.contact.email')}
        </Button>
        <Button href={site.linkedin} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
          {t('section.contact.linkedin')}
        </Button>
      </div>
    </div>
  </div>
</section>
