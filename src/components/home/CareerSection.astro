---
import { useTranslations, type Lang } from '../../i18n/index';
import experiencesData from '../../../data/experiences.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const { experiences } = experiencesData;
---

<section class="mb-10">
  <div class="section-label">{t('section.career.title')}</div>

  <div>
    {experiences.map((exp) => {
      const role = exp.role[lang];
      const description = exp.description[lang];
      const endLabel = exp.period.end ?? t('common.present');

      return (
        <div class="cv-entry">
          <div class="cv-date">
            {exp.period.start}–{endLabel}
          </div>
          <div>
            <div class="flex items-baseline gap-2 flex-wrap mb-0.5">
              <span class="font-semibold text-gray-900 text-[13px]">{role}</span>
              <span class="text-gray-400 text-xs">·</span>
              <span class="text-gray-700 text-[13px]">{exp.company}</span>
              {exp.client && (
                <span class="text-gray-400 text-xs">({exp.client})</span>
              )}
              {exp.current && (
                <span class="text-[10px] text-green-600 font-medium">{lang === 'en' ? 'current' : 'en cours'}</span>
              )}
            </div>
            <p class="text-gray-500 text-[12px] leading-relaxed mb-1.5">
              {description}
            </p>
            <div class="flex flex-wrap gap-1">
              {exp.stack.map((tech: string) => (
                <span class="text-[10px] bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded">{tech}</span>
              ))}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>
