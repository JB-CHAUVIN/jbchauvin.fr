---
import { useTranslations, type Lang } from '../../i18n/index';
import skillsData from '../../../data/skills.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const { categories } = skillsData;
---

<div class="p-4">
  <hr class="rainbow-hr" />

  <table cellpadding="0" cellspacing="0" class="w-full mb-4">
    <tr>
      <td class="bg-[#000080] p-2">
        <h2 class="!text-white text-[18px] m-0 font-display">
          &#128296; {t('section.skills.title')}
        </h2>
        <span class="font-pixel text-[11px] text-[#00FFFF]">{t('section.skills.subtitle')}</span>
      </td>
    </tr>
  </table>

  <!-- Skills displayed as nested tables, very 90s -->
  <table cellpadding="4" cellspacing="4" class="w-full">
    <tr>
      {categories.slice(0, 3).map((cat) => {
        const label = cat.label[lang as 'en' | 'fr'];
        return (
          <td class="align-top" style="width: 33%;">
            <div class="retro-card reveal">
              <div class="bg-[#000080] text-white font-display text-[12px] px-2 py-1 mb-2">
                {cat.icon} {label}
              </div>
              <div class="flex flex-wrap gap-1">
                {cat.skills.map((skill: string) => (
                  <span class="retro-tag">{skill}</span>
                ))}
              </div>
            </div>
          </td>
        );
      })}
    </tr>
    {categories.length > 3 && (
      <tr>
        {categories.slice(3, 6).map((cat) => {
          const label = cat.label[lang as 'en' | 'fr'];
          return (
            <td class="align-top" style="width: 33%;">
              <div class="retro-card reveal">
                <div class="bg-[#000080] text-white font-display text-[12px] px-2 py-1 mb-2">
                  {cat.icon} {label}
                </div>
                <div class="flex flex-wrap gap-1">
                  {cat.skills.map((skill: string) => (
                    <span class="retro-tag">{skill}</span>
                  ))}
                </div>
              </div>
            </td>
          );
        })}
        {/* Fill remaining cells if less than 3 items */}
        {categories.slice(3, 6).length < 3 && Array.from({ length: 3 - categories.slice(3, 6).length }).map(() => (
          <td></td>
        ))}
      </tr>
    )}
    {categories.length > 6 && (
      <tr>
        {categories.slice(6).map((cat) => {
          const label = cat.label[lang as 'en' | 'fr'];
          return (
            <td class="align-top" style="width: 33%;">
              <div class="retro-card reveal">
                <div class="bg-[#000080] text-white font-display text-[12px] px-2 py-1 mb-2">
                  {cat.icon} {label}
                </div>
                <div class="flex flex-wrap gap-1">
                  {cat.skills.map((skill: string) => (
                    <span class="retro-tag">{skill}</span>
                  ))}
                </div>
              </div>
            </td>
          );
        })}
        {categories.slice(6).length < 3 && Array.from({ length: 3 - categories.slice(6).length }).map(() => (
          <td></td>
        ))}
      </tr>
    )}
  </table>
</div>
