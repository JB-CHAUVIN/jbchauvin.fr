---
import { useTranslations, type Lang } from '../../i18n/index';
import skillsData from '../../../data/skills.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const { categories } = skillsData;
---

<section class="mb-10">
  <div class="section-label">{t('section.skills.title')}</div>

  <div>
    {categories.map((cat) => (
      <div class="skill-entry">
        <div class="skill-cat">{cat.label[lang as 'en' | 'fr']}</div>
        <div class="skill-list">{cat.skills.join(' · ')}</div>
      </div>
    ))}
  </div>
</section>
