---
import { useTranslations, type Lang } from '../../i18n/index';
import SectionTitle from '../ui/SectionTitle.astro';
import skillsData from '../../../data/skills.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const { categories } = skillsData;
---

<section class="bg-surface border-y border-border">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-24">
    <SectionTitle subtitle={t('section.skills.subtitle')}>
      {t('section.skills.title')}
    </SectionTitle>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((cat, i) => {
        const label = cat.label[lang as 'en' | 'fr'];
        const delayClass = `reveal-delay-${Math.min(i + 1, 4)}`;
        return (
          <div class={`reveal ${delayClass} bg-bg border border-border rounded-sm p-6`}>
            <!-- Category header -->
            <div class="flex items-center gap-2.5 mb-4">
              <span class="text-xl" aria-hidden="true">{cat.icon}</span>
              <h3 class="font-body text-sm font-semibold text-ink-primary uppercase tracking-widest">
                {label}
              </h3>
            </div>

            <!-- Skills pills -->
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill: string) => (
                <span class="font-body text-sm text-ink-secondary bg-surface border border-border px-3 py-1 rounded-sm hover:border-accent hover:text-accent transition-colors duration-200">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
