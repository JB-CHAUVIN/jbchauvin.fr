---
import Button from '../ui/Button.astro';
import AIChatSummary from './AIChatSummary.astro';
import { useTranslations, type Lang } from '../../i18n/index';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projectsHref = lang === 'en' ? '/projects/' : '/fr/projets/';
---

<section class="relative min-h-[90vh] flex">
  <!-- Background texture -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-accent/5 rounded-full blur-3xl translate-x-1/2"></div>
    <div class="absolute bottom-1/4 left-0 w-64 h-64 bg-accent/3 rounded-full blur-3xl -translate-x-1/3"></div>
  </div>

  <div class="max-w-6xl mx-auto relative w-full flex items-stretch">

    <!-- Left column: text content -->
    <div class="flex-1 min-w-0 flex items-center px-6 lg:px-8 py-24">
      <div class="max-w-xl w-full">
        <!-- Title -->
        <h1 class="reveal reveal-delay-1 font-display font-bold text-ink-primary leading-tight mb-4" style="font-size: clamp(2.5rem, 6vw, 4rem); letter-spacing: -0.02em;">
          {t('hero.title')}
        </h1>

        <!-- Subtitle -->
        <p class="reveal reveal-delay-2 font-display text-2xl md:text-3xl text-accent font-semibold mb-5">
          {t('hero.subtitle')}
        </p>

        <!-- Tagline -->
        <p class="reveal reveal-delay-2 font-body text-xl text-ink-secondary mb-4 leading-relaxed">
          {t('hero.tagline')}
        </p>

        <!-- Description -->
        <p class="reveal reveal-delay-3 font-body text-lg text-ink-secondary mb-8 leading-relaxed [&_strong]:text-ink-primary [&_strong]:font-semibold" set:html={t('hero.description')} />

        <!-- AI Chat Summary -->
        <AIChatSummary lang={lang} />

        <!-- CTAs -->
        <div class="reveal reveal-delay-4 mt-8 flex flex-wrap gap-4">
          <Button href={projectsHref} variant="primary" size="lg">
            {t('hero.cta.projects')}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </Button>
          <Button href={`mailto:${site.email}`} variant="secondary" size="lg">
            {t('hero.cta.contact')}
          </Button>
        </div>

        <!-- Stats -->
        <div class="reveal reveal-delay-4 mt-12 flex flex-wrap gap-10 border-t border-border pt-8">
          <div>
            <p class="font-display text-4xl font-bold text-ink-primary">10+</p>
            <p class="font-body text-sm text-ink-muted mt-1">{lang === 'en' ? 'Years experience' : "Ans d'expérience"}</p>
          </div>
          <div>
            <p class="font-display text-4xl font-bold text-ink-primary">13</p>
            <p class="font-body text-sm text-ink-muted mt-1">{lang === 'en' ? 'Products shipped' : 'Produits livrés'}</p>
          </div>
          <div>
            <p class="font-display text-4xl font-bold text-ink-primary">170k+</p>
            <p class="font-body text-sm text-ink-muted mt-1">{lang === 'en' ? 'Users reached' : 'Utilisateurs atteints'}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right column: photo -->
    <div class="hidden lg:flex items-center shrink-0 px-8">
      <img
        src="/images/profile.jpg"
        alt="Jean-Baptiste Chauvin - Engineering Manager · hands-on"
        class="max-h-[500px] w-auto object-contain rounded-sm"
        onerror="this.style.display='none'"
      />
    </div>

  </div>
</section>
