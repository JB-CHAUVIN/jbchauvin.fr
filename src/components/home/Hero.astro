---
import { useTranslations, type Lang } from '../../i18n/index';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const isEn = lang === 'en';
const projectsHref = isEn ? '/projects/' : '/fr/projets/';
---

<section class="pb-10 border-b border-gray-200 mb-10">
  <div class="flex items-start justify-between gap-6">
    <div class="flex-1 min-w-0">

      <!-- Name & Title -->
      <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-1">
        Jean-Baptiste Chauvin
      </h1>
      <p class="text-base text-gray-500 mb-4">
        Engineering Manager · hands-on &nbsp;·&nbsp; Paris, France
      </p>

      <!-- Contact info -->
      <p class="text-sm text-gray-500 mb-5 flex flex-wrap gap-x-3 gap-y-1">
        <a href={`mailto:${site.email}`} class="text-blue-700 hover:underline">{site.email}</a>
        <span class="text-gray-300">·</span>
        <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="text-blue-700 hover:underline">LinkedIn</a>
        <span class="text-gray-300">·</span>
        <a href={site.github} target="_blank" rel="noopener noreferrer" class="text-blue-700 hover:underline">GitHub</a>
      </p>

      <!-- Description -->
      <p
        class="text-sm text-gray-700 leading-relaxed max-w-xl mb-5 [&_strong]:font-semibold [&_strong]:text-gray-900"
        set:html={t('hero.description')}
      />

      <!-- Status -->
      <p class="text-sm text-gray-500 flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></span>
        {t('hero.available')}
      </p>
    </div>

    <!-- Photo -->
    <div class="hidden sm:block flex-shrink-0 mt-1">
      <img
        src="/images/profile.jpg"
        alt="Jean-Baptiste Chauvin"
        class="w-[72px] h-[72px] rounded-full object-cover grayscale opacity-90"
      />
    </div>
  </div>

  <!-- Stats -->
  <div class="flex items-center gap-8 mt-8 pt-6 border-t border-gray-100">
    <div>
      <div class="text-xl font-bold text-gray-900 tabular-nums">10+</div>
      <div class="text-xs text-gray-400 mt-0.5">{isEn ? 'years exp.' : "ans d'exp."}</div>
    </div>
    <div class="w-px h-8 bg-gray-200"></div>
    <div>
      <div class="text-xl font-bold text-gray-900 tabular-nums">13</div>
      <div class="text-xs text-gray-400 mt-0.5">{isEn ? 'products' : 'projets'}</div>
    </div>
    <div class="w-px h-8 bg-gray-200"></div>
    <div>
      <div class="text-xl font-bold text-gray-900 tabular-nums">170k+</div>
      <div class="text-xs text-gray-400 mt-0.5">{isEn ? 'users' : 'utilisateurs'}</div>
    </div>
    <div class="flex-1"></div>
    <a
      href={projectsHref}
      class="text-sm text-gray-700 border border-gray-300 rounded px-4 py-2 hover:border-gray-500 hover:text-gray-900 transition-colors hidden sm:inline-flex items-center gap-1"
    >
      {t('hero.cta.projects')} →
    </a>
  </div>
</section>
