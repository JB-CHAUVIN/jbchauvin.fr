---
import { useTranslations, type Lang } from '../../i18n/index';
import site from '../../../data/site.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projectsHref = lang === 'en' ? '/projects/' : '/fr/projets/';
---

<!-- Welcome section -->
<div class="reveal p-4">
  <!-- Title with retro flair -->
  <table cellpadding="0" cellspacing="0" class="w-full mb-4">
    <tr>
      <td class="bg-[#000080] p-3 text-center">
        <h1 class="!text-white text-[28px] md:text-[36px] m-0 font-display">
          ★ {t('hero.title')} ★
        </h1>
        <div class="text-[#FFFF00] font-display text-[16px] mt-1">
          {t('hero.subtitle')}
        </div>
      </td>
    </tr>
  </table>

  <!-- Two column layout: info + photo -->
  <table cellpadding="8" cellspacing="0" class="retro-table w-full mb-4">
    <tr>
      <td class="align-top" style="width: 65%;">
        <!-- Status badge -->
        <div class="mb-3">
          <span class="retro-tag-accent retro-tag">
            ● {lang === 'en' ? 'Available for opportunities' : 'Disponible'}
          </span>
        </div>

        <!-- Tagline -->
        <p class="font-body text-[15px] text-ink-secondary mb-2">
          {t('hero.tagline')}
        </p>

        <!-- Description -->
        <p class="font-body text-[14px] text-ink-primary leading-relaxed mb-4 [&_strong]:text-[#000080] [&_strong]:font-bold" set:html={t('hero.description')} />

        <!-- CTAs -->
        <div class="flex flex-wrap gap-2 mt-4">
          <a href={projectsHref} class="retro-btn retro-btn-primary no-underline">
            &#128194; {t('hero.cta.projects')}
          </a>
          <a href={`mailto:${site.email}`} class="retro-btn no-underline">
            &#9993; {t('hero.cta.contact')}
          </a>
        </div>
      </td>
      <td class="align-top text-center hidden md:table-cell">
        <!-- Photo -->
        <div class="win-panel inline-block">
          <div class="border-inset p-1">
            <img
              src="/images/profile.jpg"
              alt="Jean-Baptiste Chauvin"
              class="max-h-[200px] w-auto"
              style="image-rendering: auto;"
              onerror="this.parentElement.parentElement.innerHTML='<div style=&quot;width:150px;height:150px;background:#000080;display:flex;align-items:center;justify-content:center;color:#FFFF00;font-size:48px;font-family:Comic Sans MS,cursive;&quot;>JB</div>'"
            />
          </div>
        </div>
        <div class="font-pixel text-[10px] text-ink-muted mt-1">profile.jpg (48KB)</div>
      </td>
    </tr>
  </table>

  <!-- AI Chat Summary -->
  <slot name="ai-summary" />

  <hr class="rainbow-hr" />

  <!-- Stats table -->
  <table cellpadding="6" cellspacing="0" class="retro-table w-full md:w-auto mx-auto">
    <tr>
      <th colspan="3" class="text-center">
        &#128202; {lang === 'en' ? 'Stats' : 'Statistiques'}
      </th>
    </tr>
    <tr>
      <td class="text-center">
        <div class="font-display text-[24px] text-[#000080] font-bold">10+</div>
        <div class="font-pixel text-[11px] text-ink-muted">{lang === 'en' ? 'Years exp.' : "Ans d'exp."}</div>
      </td>
      <td class="text-center">
        <div class="font-display text-[24px] text-[#000080] font-bold">13</div>
        <div class="font-pixel text-[11px] text-ink-muted">{lang === 'en' ? 'Products' : 'Produits'}</div>
      </td>
      <td class="text-center">
        <div class="font-display text-[24px] text-[#000080] font-bold">170k+</div>
        <div class="font-pixel text-[11px] text-ink-muted">{lang === 'en' ? 'Users' : 'Utilisateurs'}</div>
      </td>
    </tr>
  </table>
</div>
