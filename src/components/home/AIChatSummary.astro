---
interface Props {
  lang: 'en' | 'fr';
}

const { lang } = Astro.props;

const content = {
  en: {
    label: 'AI Summary',
    sub: 'Generated from profile data',
    text: `Jean-Baptiste is a hands-on Engineering Manager and full-stack mobile specialist — one of those rare profiles that scales teams without losing sight of the codebase.\n\n• 10+ years across mobile (React Native) and web (React, PHP)\n• Led 10 engineers at Cegedim Santé — apps used by 170k+ people\n• 13 shipped products: iOS, Android, web, Garmin — mostly solo\n• Stack: React Native · React · TypeScript · Node.js · PHP · AWS · AI APIs\n• 10 LinkedIn recommendations: direct reports, CTOs, clients — all unanimous`,
  },
  fr: {
    label: 'Résumé IA',
    sub: 'Généré depuis les données du profil',
    text: `Jean-Baptiste est un Engineering Manager hands-on et spécialiste mobile & web full-stack — l'un de ces profils rares qui fait grandir des équipes sans perdre le contact avec le code.\n\n• 10+ ans entre mobile (React Native) et web (React, PHP)\n• 10 ingénieurs managés chez Cegedim Santé — apps utilisées par 170k+ personnes\n• 13 projets livrés : iOS, Android, web, Garmin — souvent en solo\n• Stack : React Native · React · TypeScript · Node.js · PHP · AWS · APIs IA\n• 10 recommandations LinkedIn : collègues, CTOs, clients — unanimes`,
  },
}[lang];
---

<div class="ai-chat-block reveal reveal-delay-4 mt-6 mb-4 win-panel" data-ai-text={content.text}>
  <!-- Title bar like a terminal window -->
  <div class="win-titlebar" style="background: linear-gradient(90deg, #000000, #333333);">
    <span>
      C:\AI\summary.exe
    </span>
    <div class="flex gap-1">
      <span class="inline-block w-[14px] h-[14px] bg-[#C0C0C0] border border-solid text-center leading-[12px] text-[10px] text-black" style="border-color: #FFFFFF #808080 #808080 #FFFFFF;">_</span>
      <span class="inline-block w-[14px] h-[14px] bg-[#C0C0C0] border border-solid text-center leading-[12px] text-[10px] text-black" style="border-color: #FFFFFF #808080 #808080 #FFFFFF;">×</span>
    </div>
  </div>

  <!-- Terminal content -->
  <div class="bg-black p-3 border-inset">
    <div class="font-mono text-[11px] text-[#00FF00] mb-1">
      &gt; {content.label} — <span class="text-[#808080]">{content.sub}</span>
    </div>
    <p
      id="ai-chat-text"
      class="font-mono text-[12px] text-[#00FF00] leading-relaxed whitespace-pre-line ai-typed-text"
      aria-label={content.text}
    ></p>
    <span id="ai-cursor" class="inline-block w-[8px] h-[14px] bg-[#00FF00] align-middle blink" aria-hidden="true"></span>
  </div>
</div>

<style>
  .ai-typed-text {
    min-height: 1.5em;
  }
</style>

<script>
  (function () {
    const block = document.querySelector('.ai-chat-block') as HTMLElement | null;
    const output = document.getElementById('ai-chat-text') as HTMLElement | null;
    const cursor = document.getElementById('ai-cursor') as HTMLElement | null;

    if (!block || !output || !cursor) return;

    const fullText = block.dataset.aiText || '';
    let started = false;

    function typeText() {
      if (started) return;
      started = true;

      let i = 0;
      const CHUNK = 2;
      const DELAY = 25;

      setTimeout(() => {
        const interval = setInterval(() => {
          i = Math.min(i + CHUNK, fullText.length);
          output!.textContent = fullText.slice(0, i);
          if (i >= fullText.length) {
            clearInterval(interval);
            setTimeout(() => {
              if (cursor) cursor.style.display = 'none';
            }, 2000);
          }
        }, DELAY);
      }, 600);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            typeText();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(block);
  })();
</script>
