---
import { type Lang } from '../../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const degrees = [
  {
    degree: { en: 'Master MIAGE — Bac +5', fr: 'Master MIAGE — Bac +5' },
    school: { en: 'Université Paris Nanterre', fr: 'Université Paris Nanterre' },
    period: '2015–2017',
    detail: {
      en: 'Computer Methods Applied to Business Management · Graduated 15/20',
      fr: 'Méthodes Informatiques Appliquées à la Gestion des Entreprises · Mention 15/20',
    },
    highlight: {
      en: 'Founded WITIP — the Junior Enterprise of MIAGE Nanterre.',
      fr: 'Fondateur de WITIP — la Junior Entreprise de la MIAGE de Nanterre.',
    },
  },
  {
    degree: { en: 'BTS IRIS — Bac +2', fr: 'BTS IRIS — Bac +2' },
    school: { en: 'Lycée technique', fr: 'Lycée technique' },
    period: '2013–2015',
    detail: {
      en: 'Computer Science & Networks',
      fr: 'Informatique & Réseaux des Systèmes',
    },
    highlight: null,
  },
];
---

<section class="mb-10">
  <div class="section-label">{lang === 'en' ? 'Education' : 'Formation'}</div>

  <div>
    {degrees.map((d) => (
      <div class="cv-entry">
        <div class="cv-date">{d.period}</div>
        <div>
          <div class="flex items-baseline gap-2 flex-wrap mb-0.5">
            <span class="font-semibold text-gray-900 text-[13px]">{d.degree[lang]}</span>
            <span class="text-gray-400 text-xs">·</span>
            <span class="text-gray-700 text-[13px]">{d.school[lang]}</span>
          </div>
          <p class="text-gray-500 text-[12px] leading-relaxed">{d.detail[lang]}</p>
          {d.highlight && (
            <p class="text-gray-400 text-[11px] mt-0.5 italic">{d.highlight[lang]}</p>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
