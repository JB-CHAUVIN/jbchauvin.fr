---
import { useTranslations, type Lang } from '../../i18n/index';

interface Props {
  lang: Lang;
  references: any[];
}

const { lang, references } = Astro.props;
const t = useTranslations(lang);

const allReferencesHref = lang === 'en' ? '/references/' : '/fr/references/';
const featured = references.slice(0, 2);
---

<div class="p-4">
  <hr class="rainbow-hr" />

  <table cellpadding="0" cellspacing="0" class="w-full mb-4">
    <tr>
      <td class="bg-[#000080] p-2">
        <h2 class="!text-white text-[18px] m-0 font-display">
          &#128172; {t('section.references.title')}
        </h2>
        <span class="font-pixel text-[11px] text-[#00FFFF]">{t('section.references.subtitle')}</span>
      </td>
    </tr>
  </table>

  <!-- Guestbook-style references -->
  {featured.map((ref) => {
    const testimonial = ref.testimonial[lang];
    const role = ref.role[lang];
    const previewText = testimonial.text.length > 280
      ? testimonial.text.slice(0, 280).trimEnd() + '…'
      : testimonial.text;
    const initials = testimonial.author.split(' ').map((n: string) => n[0]).slice(0, 2).join('');

    return (
      <div class="retro-card reveal mb-3">
        <table cellpadding="4" cellspacing="0" class="w-full">
          <tr>
            <td class="align-top" style="width: 50px;">
              <!-- Avatar area -->
              <div class="w-[40px] h-[40px] bg-[#000080] border-inset flex items-center justify-center text-white font-display text-[14px] overflow-hidden">
                {ref.avatar ? (
                  <img
                    src={ref.avatar}
                    alt={testimonial.author}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    onerror={`this.style.display='none'; this.parentElement.innerHTML='<span style="font-family:Comic Sans MS,cursive;font-size:14px;">${initials}</span>'`}
                  />
                ) : (
                  <span>{initials}</span>
                )}
              </div>
            </td>
            <td class="align-top">
              <div class="font-display text-[13px] text-[#000080] font-bold">
                {testimonial.author}
                <span class="font-pixel text-[10px] text-ink-muted font-normal ml-2">
                  {testimonial.position} — {ref.company}
                </span>
              </div>
              <div class="font-pixel text-[10px] text-ink-muted mb-2">{ref.period}</div>
              <blockquote class="font-body text-[13px] text-ink-secondary leading-relaxed italic border-l-2 border-[#808080] pl-2">
                "{previewText}"
              </blockquote>
              <div class="mt-1">
                {ref.stack.map((tech: string) => (
                  <span class="retro-tag mr-1">{tech}</span>
                ))}
              </div>
            </td>
          </tr>
        </table>
      </div>
    );
  })}

  <div class="mt-3 text-center">
    <a href={allReferencesHref} class="retro-btn no-underline">
      {t('section.references.cta')} ({references.length}) &#9654;
    </a>
  </div>
</div>
