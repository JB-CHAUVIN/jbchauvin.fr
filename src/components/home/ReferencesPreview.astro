---
import { useTranslations, type Lang } from '../../i18n/index';

interface Props {
  lang: Lang;
  references: any[];
}

const { lang, references } = Astro.props;
const t = useTranslations(lang);
const allReferencesHref = lang === 'en' ? '/references/' : '/fr/references/';
const featured = references.slice(0, 2);
---

<section class="mb-10">
  <div class="section-label">{t('section.references.title')}</div>

  <div class="space-y-6">
    {featured.map((ref) => {
      const testimonial = ref.testimonial[lang];
      const previewText = testimonial.text.length > 240
        ? testimonial.text.slice(0, 240).trimEnd() + '…'
        : testimonial.text;

      return (
        <div class="border-l-2 border-gray-200 pl-4 py-1">
          <blockquote class="text-sm text-gray-600 leading-relaxed italic mb-2">
            "{previewText}"
          </blockquote>
          <div class="flex items-center gap-2">
            {ref.avatar && (
              <img
                src={ref.avatar}
                alt={testimonial.author}
                class="w-6 h-6 rounded-full object-cover grayscale flex-shrink-0"
                loading="lazy"
              />
            )}
            <div class="text-xs text-gray-500">
              <span class="font-semibold text-gray-700">{testimonial.author}</span>
              &nbsp;·&nbsp;{testimonial.position}&nbsp;·&nbsp;{ref.period}
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <div class="mt-5">
    <a href={allReferencesHref} class="text-sm text-blue-700 hover:underline">
      {t('section.references.cta')} ({references.length}) →
    </a>
  </div>
</section>
