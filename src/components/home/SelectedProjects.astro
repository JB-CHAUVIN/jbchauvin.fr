---
import { useTranslations, type Lang } from '../../i18n/index';

interface Props {
  lang: Lang;
  projects: any[];
}

const { lang, projects } = Astro.props;
const t = useTranslations(lang);
const allProjectsHref = lang === 'en' ? '/projects/' : '/fr/projets/';
const featured = projects.slice(0, 5);
---

<section class="mb-10">
  <div class="section-label">{t('section.projects.title')}</div>

  <div>
    {featured.map((project) => {
      const content = project.content[lang];
      const images = (project.images ?? []).map((img: string) => `/images/projects/${img}`);

      return (
        <div class="cv-entry">
          <div class="cv-date">
            {project.date.slice(0, 4)}
            <div class="text-[10px] text-gray-400 mt-0.5">{project.type}</div>
          </div>
          <div>
            <div class="flex items-baseline gap-2 flex-wrap mb-0.5">
              <span class="font-semibold text-gray-900 text-[13px]">{content.title}</span>
              <span class="text-gray-400 text-[11px]">{project.role}</span>
              {project.users !== null && (
                <span class="text-gray-400 text-[11px]">
                  · {project.users >= 1000 ? `${Math.round(project.users / 1000)}k` : project.users}+ {t('projects.users')}
                </span>
              )}
              {project.users === null && (
                <span class="text-gray-400 text-[11px]">· MVP</span>
              )}
            </div>
            <p class="text-gray-500 text-[12px] mb-1.5">{content.shortDescription}</p>
            <div class="flex flex-wrap items-center gap-3">
              {project.links?.ios && (
                <a href={project.links.ios} target="_blank" rel="noopener noreferrer" class="text-[11px] text-blue-700 hover:underline">App Store ↗</a>
              )}
              {project.links?.android && (
                <a href={project.links.android} target="_blank" rel="noopener noreferrer" class="text-[11px] text-blue-700 hover:underline">Play Store ↗</a>
              )}
              {project.links?.web && (
                <a href={project.links.web} target="_blank" rel="noopener noreferrer" class="text-[11px] text-blue-700 hover:underline">{lang === 'en' ? 'Website' : 'Site web'} ↗</a>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <div class="mt-4 pt-2">
    <a href={allProjectsHref} class="text-sm text-blue-700 hover:underline">
      {t('section.projects.cta')} →
    </a>
  </div>
</section>
