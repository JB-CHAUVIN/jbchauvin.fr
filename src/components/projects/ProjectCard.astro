---
import Tag from '../ui/Tag.astro';
import { type Lang } from '../../i18n/index';

interface Props {
  project: any;
  lang: Lang;
  usersLabel: string;
}

const { project, lang, usersLabel } = Astro.props;
const content = project.content[lang];
const images = (project.images ?? []).map((img: string) => `/images/projects/${img}`);
const heroImage = images[0] ?? null;
---

<article class="glass rounded-2xl overflow-hidden card-hover card-glow flex flex-col h-full group">
  <!-- Hero image -->
  <div
    class="relative overflow-hidden bg-surface-solid cursor-pointer"
    style="height: 220px;"
    onclick={`window.dispatchEvent(new CustomEvent('open-lightbox',{detail:{images:${JSON.stringify(images)},index:0,projectTitle:${JSON.stringify(content.title)}}}))`}
  >
    {heroImage ? (
      <>
        <img
          src={heroImage}
          alt={content.title}
          class="absolute inset-0 w-full h-full object-contain object-center group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        {images.length > 1 && (
          <div class="absolute bottom-2 right-2 glass text-white font-body text-xs px-2 py-0.5 rounded-lg z-10">
            +{images.length - 1}
          </div>
        )}
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
          <div class="glass text-white rounded-full p-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </>
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="font-display text-5xl font-bold text-gradient">{content.title.charAt(0)}</span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center justify-between mb-3">
      <Tag variant="accent">{project.type}</Tag>
      <div class="flex items-center gap-2">
        {project.users === null && (
          <span class="font-body text-xs font-medium uppercase tracking-widest px-1.5 py-0.5 rounded-md border border-ink-muted/30 text-ink-muted/70">MVP</span>
        )}
        <span class="font-body text-xs text-ink-muted">{project.date.slice(0, 4)}</span>
      </div>
    </div>

    <h2 class="font-display text-xl font-semibold text-ink-primary mb-2 group-hover:text-gradient transition-all duration-300">
      {content.title}
    </h2>

    <p class="font-body text-sm text-ink-secondary leading-relaxed mb-3">
      {content.shortDescription}
    </p>

    <p class="font-body text-sm text-ink-muted leading-relaxed mb-5 flex-1">
      {content.longDescription}
    </p>

    <div class="flex flex-wrap gap-1.5 mb-4">
      {project.stack.map((tech: string) => (
        <Tag variant="muted">{tech}</Tag>
      ))}
    </div>

    <div class="flex items-center justify-between pt-4 border-t border-border flex-wrap gap-2">
      <div class="flex items-center gap-2">
        <Tag variant="default">{project.role}</Tag>
        {project.users && (
          <span class="font-body text-xs text-ink-muted">
            {project.users >= 1000 ? `${Math.round(project.users / 1000)}k` : project.users}+ {usersLabel}
          </span>
        )}
      </div>

      <div class="flex items-center gap-2">
        {project.links?.ios && (
          <a
            href={project.links.ios}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 font-body text-xs font-medium text-ink-muted border border-border px-2.5 py-1 rounded-lg hover:border-accent hover:text-accent transition-all duration-300"
            onclick="event.stopPropagation()"
          >
            iOS
          </a>
        )}
        {project.links?.android && (
          <a
            href={project.links.android}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 font-body text-xs font-medium text-ink-muted border border-border px-2.5 py-1 rounded-lg hover:border-accent hover:text-accent transition-all duration-300"
            onclick="event.stopPropagation()"
          >
            Android
          </a>
        )}
        {project.links?.web && (
          <a
            href={project.links.web}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 font-body text-xs font-medium text-ink-muted border border-border px-2.5 py-1 rounded-lg hover:border-accent hover:text-accent transition-all duration-300"
            onclick="event.stopPropagation()"
          >
            Web
          </a>
        )}
      </div>
    </div>
  </div>
</article>
