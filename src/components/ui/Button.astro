---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  target,
  rel,
} = Astro.props;

const base = 'inline-flex items-center gap-2 font-body font-medium transition-all duration-300 rounded-xl';

const variants = {
  primary: 'bg-gradient-aurora text-white hover:opacity-90 hover:shadow-glow',
  secondary: 'border border-border text-ink-primary hover:border-accent hover:text-accent glass',
  ghost: 'text-accent hover:text-accent-cyan underline underline-offset-4 decoration-accent/30 hover:decoration-accent-cyan/50',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const classes = [base, variants[variant], sizes[size], className].join(' ');
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
