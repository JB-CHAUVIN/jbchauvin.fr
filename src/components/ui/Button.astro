---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  target,
  rel,
} = Astro.props;

const variantClasses = {
  primary: 'retro-btn retro-btn-primary',
  secondary: 'retro-btn',
  ghost: 'font-pixel text-[12px] text-[#0000FF] hover:text-[#FF0000] underline',
};

const sizeClasses = {
  sm: 'text-[11px] px-2 py-1',
  md: '',
  lg: 'text-[14px] px-4 py-2',
};

const classes = [variantClasses[variant], sizeClasses[size], 'no-underline', className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
