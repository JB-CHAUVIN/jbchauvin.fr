---
interface Props {
  variant?: 'default' | 'accent' | 'muted';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variants = {
  default: 'retro-tag',
  accent: 'retro-tag retro-tag-accent',
  muted: 'retro-tag',
};

const classes = [variants[variant], className].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
</span>
