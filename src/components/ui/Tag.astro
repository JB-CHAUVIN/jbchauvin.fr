---
interface Props {
  variant?: 'default' | 'accent' | 'muted';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variants = {
  default: 'bg-border text-ink-secondary',
  accent: 'bg-accent-light text-accent',
  muted: 'bg-surface text-ink-muted border border-border',
};

const classes = [
  'inline-flex items-center px-2.5 py-0.5 rounded-sm',
  'font-body text-xs uppercase tracking-widest font-medium',
  variants[variant],
  className,
].join(' ');
---

<span class={classes}>
  <slot />
</span>
