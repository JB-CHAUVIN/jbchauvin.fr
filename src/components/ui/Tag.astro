---
interface Props {
  variant?: 'default' | 'accent' | 'muted';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variants = {
  default: 'bg-gray-100 text-gray-600',
  accent: 'bg-gray-900 text-white',
  muted: 'bg-gray-50 text-gray-400',
};

const classes = [
  'inline-block text-[11px] font-medium px-2 py-0.5 rounded',
  variants[variant],
  className,
].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
</span>
