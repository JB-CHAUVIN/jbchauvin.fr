---
interface Props {
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { subtitle, align = 'left', class: className = '' } = Astro.props;
---

<div class={`mb-8 ${className}`}>
  <h1 class={`text-2xl font-bold text-gray-900 tracking-tight mb-1 ${align === 'center' ? 'text-center' : ''}`}>
    <slot />
  </h1>
  {subtitle && (
    <p class={`text-sm text-gray-500 ${align === 'center' ? 'text-center' : ''}`}>
      {subtitle}
    </p>
  )}
</div>
