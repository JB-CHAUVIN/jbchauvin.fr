---
interface Props {
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { subtitle, align = 'left', class: className = '' } = Astro.props;
---

<div class={`mb-4 ${className}`}>
  <table cellpadding="0" cellspacing="0" class="w-full">
    <tr>
      <td class="bg-[#000080] p-2">
        <h2 class="!text-white text-[18px] m-0 font-display" style={align === 'center' ? 'text-align: center;' : ''}>
          <slot />
        </h2>
        {subtitle && (
          <div class="font-pixel text-[11px] text-[#00FFFF]" style={align === 'center' ? 'text-align: center;' : ''}>
            {subtitle}
          </div>
        )}
      </td>
    </tr>
  </table>
</div>
