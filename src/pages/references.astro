---
import Layout from '../components/layout/Layout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import ReferenceCard from '../components/references/ReferenceCard.astro';
import { useTranslations } from '../i18n/index';
import referencesData from '../../data/references.json';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout
  title="References — Jean-Baptiste Chauvin"
  description="Professional references and testimonials from companies Jean-Baptiste Chauvin has worked with."
>
  <div class="p-4">
    <SectionTitle subtitle={t('references.subtitle')}>
      &#128172; {t('references.title')}
    </SectionTitle>

    {referencesData.references.map((ref) => (
      <ReferenceCard reference={ref} lang={lang} />
    ))}
  </div>
</Layout>
